{
  "name": "mdm-util",
  "version": "1.10.0",
  "private": true,
  "main": "dist/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./dist/index.js"
    },
    "./redis": {
      "types": "./redis.d.ts",
      "default": "./dist/redis/createRedisClient.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "redis": "5.10.0",
    "uuid": "11.1.0"
  }
}
