{
  "name": "notes-api",
  "version": "1.7.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "turbo run build --filter=notes-api^...",
    "predev": "turbo run build --filter=notes-api^...",
    "pretest": "turbo run build --filter=notes-api^...",
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "app-config": "1.7.0",
    "express": "5.2.1",
    "markdown": "1.7.0",
    "mdm-util": "1.7.0",
    "morgan": "1.10.1",
    "remark": "13.0.0",
    "remark-gfm": "1.0.0",
    "remark-html": "13.0.2"
  }
}
