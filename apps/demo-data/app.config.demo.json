{
  "attachmentsDirectory": "attachments",
  "dateFormats": ["YYYY-MM-DD"],
  "obsidianVault": "mdm-demo",
  "timezone": "UTC",
  "views": [
    {
      "id": "on-this-day",
      "name": "on this day",
      "group": "journal",
      "component": "NotesReview",
      "filters": [{ "folder": "journal", "frontmatter.created": "$onThisDay" }],
      "badges": ["frontmatter.mood", "frontmatter.tags"]
    },
    {
      "id": "today",
      "name": "today's entry",
      "group": "journal",
      "component": "NotesList",
      "filters": [{ "folder": "journal", "frontmatter.created": "$today" }],
      "badges": ["frontmatter.mood", "frontmatter.tags"]
    },
    {
      "id": "photo-wall",
      "name": "photo wall",
      "group": "photos",
      "component": "NotesGallery",
      "filters": [{ "folder": "photos" }],
      "badges": ["frontmatter.location", "frontmatter.tags", "frontmatter.source"],
      "notesGalleryFilters": ["location", "tags"]
    },
    {
      "id": "books",
      "name": "books",
      "group": "library",
      "component": "NotesGallery",
      "filters": [{ "folder": "library/books" }],
      "badges": ["frontmatter.author", "frontmatter.genre", "frontmatter.source"],
      "notesGalleryFilters": ["author", "genre", "status", "rating"]
    },
    {
      "id": "reading-list",
      "name": "reading list",
      "group": "library",
      "component": "NotesSummaryTable",
      "filters": [
        { "folder": "library/books", "frontmatter.status": "to-read" },
        { "folder": "library/books", "frontmatter.status": "reading" }
      ],
      "badges": ["frontmatter.author", "frontmatter.genre", "frontmatter.status"]
    },
    {
      "id": "movies",
      "name": "movies",
      "group": "library",
      "component": "NotesGallery",
      "filters": [
        { "folder": "library/movies" },
        { "$exclude": { "frontmatter.status": "watchlist" } }
      ],
      "badges": ["frontmatter.director", "frontmatter.genre", "frontmatter.rating", "frontmatter.source"],
      "notesGalleryFilters": ["director", "genre", "rating"]
    },
    {
      "id": "quote-review",
      "name": "quote review",
      "group": "library",
      "component": "NotesReview",
      "filters": [{ "folder": "quotes" }],
      "badges": ["frontmatter.author", "frontmatter.tags"]
    },
    {
      "id": "ideas",
      "name": "ideas",
      "group": "knowledge",
      "component": "NotesList",
      "filters": [{ "folder": "ideas", "frontmatter.archived": "$missing" }],
      "badges": ["frontmatter.tags"]
    },
    {
      "id": "projects",
      "name": "active projects",
      "group": "knowledge",
      "component": "NotesSummaryTable",
      "filters": [
        { "folder": "projects" },
        { "$exclude": { "frontmatter.status": "done" } }
      ],
      "badges": ["frontmatter.status", "frontmatter.tags"]
    },
    {
      "id": "recipes",
      "name": "recipes",
      "group": "knowledge",
      "component": "NotesGallery",
      "filters": [{ "folder": "recipes" }],
      "badges": ["frontmatter.cuisine", "frontmatter.difficulty", "frontmatter.source"],
      "notesGalleryFilters": ["cuisine", "difficulty"]
    }
  ],
  "habits": [
    {
      "id": "screen-time",
      "name": "screen time",
      "mode": "do-less",
      "frontmatterProperty": "screentime",
      "trackingWindowDays": 30,
      "targetScore": 100
    }
  ],
  "flags": {
    "read": {
      "expiresInDays": 30
    }
  }
}
