{
  "name": "demo-data",
  "version": "1.1.10",
  "private": true,
  "license": "MIT",
  "main": "dist/cli.js",
  "scripts": {
    "prebuild": "turbo run build --filter=demo-data^...",
    "pretest": "turbo run build --filter=demo-data^...",
    "pregenerate": "turbo run build --filter=demo-data^...",
    "generate": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
