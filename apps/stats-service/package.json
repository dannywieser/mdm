{
  "name": "stats-service",
  "version": "1.1.15",
  "private": true,
  "license": "MIT",
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "turbo run build --filter=stats-service^...",
    "predev": "turbo run build --filter=stats-service^...",
    "pretest": "turbo run build --filter=stats-service^...",
    "dev": "tsx watch --env-file=../../.env src/server.ts | pino-pretty",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "app-config": "3.0.1",
    "express": "5.2.1",
    "markdown": "3.0.1",
    "mdm-logger": "1.0.0",
    "mdm-util": "3.0.1",
    "pino-http": "11.0.0"
  }
}
