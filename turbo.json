{
  "$schema": "https://v2-9-16.turborepo.dev/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "VITE_BASE_PATH",
        "VITE_DEMO_MODE"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "typecheck": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    }
  }
}
