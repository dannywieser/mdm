{
  "attachmentsDirectory": "attachments",
  "dateFormats": ["YYYY.MM.DD", "YY/MM/DD"],
  "obsidianVault": "vault-name",
  "timezone": "America/Edmonton",
  "views": [
    {
      "id": "books",
      "name": "Books",
      "component": "NotesList",
      "filters": [
        {
          "folder": "downtime",
          "frontmatter.type": "book"
        },
        {
          "$exclude": {
            "folder": "archive"
          }
        },
        {
          "frontmatter.series": "$missing"
        }
      ],
      "badges": ["folder", "frontmatter.type", "frontmatter.genre"]
    }
  ],
  "flags": {
    "read": {
      "expiresInSeconds": 3600
    },
    "archived": {}
  }
}
