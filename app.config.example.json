{
  "attachmentsDirectory": "attachments",
  "dateFormats": ["YYYY.MM.DD", "YY/MM/DD"],
  "obsidianVault": "vault-name",
  "timezone": "America/Edmonton",
  "views": [
    {
      "id": "books",
      "name": "Books",
      "component": "NotesGallery",
      "layout": "flex",
      "filters": [
        {
          "folder": "downtime",
          "frontmatter.type": "book"
        },
        {
          "$exclude": {
            "folder": "archive"
          }
        },
        {
          "frontmatter.series": "$missing"
        }
      ],
      "badges": ["folder", "frontmatter.type", "frontmatter.genre"]
    }
  ],
  "habits": [
    {
      "id": "exercise",
      "name": "Daily Exercise",
      "mode": "do-more",
      "frontmatterProperty": "exercise",
      "trackingWindowDays": 90
    },
    {
      "id": "stress",
      "name": "Stress Level",
      "mode": "do-less",
      "frontmatterProperty": "stress",
      "trackingWindowDays": 30,
      "targetScore": 100
    }
  ],
  "flags": {
    "read": {
      "expiresInSeconds": 3600
    },
    "archived": {}
  }
}
