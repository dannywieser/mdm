# Copy this file to .env at the repository root. Every backend app's `dev`
# script loads this same shared file (`tsx watch --env-file=../../.env`).

# Required: absolute path to your Obsidian vault (a folder of .md/.markdown
# files). Read by notes-api, habit-tracker, stats-service, and image-server.
NOTES_ROOT=/absolute/path/to/your/notes

# Required: absolute path to app.config.json. `npm run dev` runs each app
# from its own workspace directory, so the code's default (./app.config.json
# relative to cwd) won't find the repo-root config file created in step 3 of
# "Getting started" - point this at that file explicitly.
APP_CONFIG_PATH=/absolute/path/to/app.config.json

# Optional: pino log level, one of fatal/error/warn/info/debug/trace.
# Defaults to "info".
# LOG_LEVEL=info

# Optional: Redis connection string, defaults to redis://localhost:6379.
# Used by flag-manager (feature flag storage) and image-server (redirect
# cache); both need a local Redis instance running for this to connect.
# REDIS_URL=redis://localhost:6379

# Optional, image-server only: max output dimensions in pixels for imgproxy
# resizing. Default to 1024x768.
# IMAGE_MAX_WIDTH=1024
# IMAGE_MAX_HEIGHT=768

# Optional, image-server only: how long (in seconds) a resolved image
# redirect is cached in Redis. Defaults to 86400 (24 hours).
# IMAGE_CACHE_TTL_SECONDS=86400

# Optional, image-server only: set to "false" to serve original images
# directly instead of proxying through imgproxy. Defaults to true.
# IMAGE_PROXY_ENABLED=true

# Optional, image-server only: path prefix imgproxy is mounted under
# (see nginx's /imgproxy route in infra/nginx/default.conf). Defaults to
# "/imgproxy".
# IMGPROXY_PATH_PREFIX=/imgproxy

# Optional, Docker Compose only: set to "watchtower" to start the
# watchtower service, which watches the published mdm-* images and
# auto-pulls + restarts any container when a new one is published (see
# the "watchtower" service in docker-compose.yml). Leave unset to opt
# out entirely - `docker compose up -d` won't start it. To turn it back
# off after enabling it, unset this and run `docker compose down
# watchtower` explicitly rather than relying on `up -d` alone.
# COMPOSE_PROFILES=watchtower
